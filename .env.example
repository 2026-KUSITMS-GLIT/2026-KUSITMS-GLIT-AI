# Copy to `.env` for local dev:  cp .env.example .env
# 배포 시에는 이 파일을 쓰지 않고 SSM 파라미터 스토어 통해서 직접 주입하도록 해주세요.

# ---- Server ----
# local | prod
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Auth (Spring Boot backend ↔ AI service) ----
# Spring Boot가 X-Internal-Token 헤더로 이 값을 실어 보내도록 설계가 필요합니다.
# 생성: python -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_TOKEN=change-me-to-a-random-32-byte-token

# ---- AI provider ----
# AI 기능을 추가할 때 아래 키들을 core/config.py 의 Settings에 필드로 선언하고 함께 사용하시면 됩니다.
# ANTHROPIC_API_KEY=sk-ant-...
